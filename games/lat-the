  color: white;
  padding: 20px;
}

.wrap {
  max-width: 1200px;
  margin: 0 auto;
}

/* ========================================
   HEADER
   ======================================== */
.site-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 2px solid rgba(255,255,255,0.1);
  margin-bottom: 24px;
  flex-wrap: wrap;
  gap: 12px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: white;
}

.seal-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: #9C3626;
  border-radius: 50%;
  font-size: 1.4rem;
  color: #f5e6d3;
  font-weight: 700;
}

.brand-text .cn {
  font-size: 1rem;
  font-weight: 600;
  color: #f5e6d3;
}

.brand-text .vn {
  font-size: 0.7rem;
  color: #aab;
}

.main-nav {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.main-nav a {
  color: #aab;
  text-decoration: none;
  padding: 6px 16px;
  border-radius: 6px;
  font-size: 0.9rem;
  transition: all 0.2s;
}

.main-nav a:hover {
  background: rgba(255,255,255,0.08);
  color: white;
}

.main-nav a.active {
  background: #9C3626;
  color: white;
}

/* ========================================
   GAME HEADER
   ======================================== */
.game-header {
  text-align: center;
  padding: 20px 0 30px;
}

.game-header h1 {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 8px;
}

.game-header .sub {
  color: #aab;
  font-size: 1rem;
}

/* ========================================
   CONTROLS
   ======================================== */
.controls {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
  align-items: center;
  margin-bottom: 24px;
  padding: 16px;
  background: rgba(255,255,255,0.05);
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.08);
}

.controls label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  color: #ccc;
}

.controls select,
.controls button {
  padding: 8px 16px;
  border-radius: 8px;
  border: none;
  font-size: 0.9rem;
  cursor: pointer;
  background: rgba(255,255,255,0.1);
  color: white;
  transition: all 0.2s;
}

.controls select {
  background: rgba(255,255,255,0.15);
  min-width: 150px;
}

.controls select option {
  background: #1a1a2e;
  color: white;
}

.controls button {
  background: #9C3626;
  font-weight: 600;
  padding: 8px 24px;
}

.controls button:hover {
  background: #b3402e;
  transform: scale(1.02);
}

.controls .stats {
  display: flex;
  gap: 20px;
  margin-left: auto;
  font-size: 0.9rem;
  color: #aab;
}

.controls .stats span {
  color: white;
  font-weight: 600;
}

/* ========================================
   GAME BOARD
   ======================================== */
.game-board {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 12px;
  max-width: 900px;
  margin: 0 auto;
  padding: 10px;
}

/* ========================================
   CARD
   ======================================== */
.card {
  aspect-ratio: 1 / 1;
  perspective: 800px;
  cursor: pointer;
}

.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}

.card.flipped .card-inner {
  transform: rotateY(180deg);
}

.card.matched .card-inner {
  transform: rotateY(180deg);
}

.card.matched {
  cursor: default;
}

.card-front,
.card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px;
  text-align: center;
  font-size: 0.85rem;
  font-weight: 600;
  border: 2px solid rgba(255,255,255,0.1);
}

/* Mặt sau (úp) */
.card-back {
  background: linear-gradient(145deg, #2a2a4a, #1a1a3a);
  border-color: rgba(255,255,255,0.15);
  color: #f5e6d3;
  font-size: 2rem;
  transform: rotateY(0deg);
  box-shadow: 0 4px 15px rgba(0,0,0,0.3);
}

.card-back::after {
  content: "?";
  opacity: 0.3;
  font-size: 2.5rem;
}

/* Mặt trước (ngửa) */
.card-front {
  background: linear-gradient(145deg, #f5e6d3, #e8d5c4);
  color: #1a1a2e;
  transform: rotateY(180deg);
  border-color: #9C3626;
  box-shadow: 0 4px 15px rgba(156, 54, 38, 0.2);
  flex-direction: column;
  gap: 4px;
}

.card-front .hanzi {
  font-size: 1.6rem;
  font-weight: 700;
  color: #1a1a2e;
}

.card-front .pinyin {
  font-size: 0.7rem;
  color: #666;
  font-weight: 400;
}

.card-front .meaning {
  font-size: 0.7rem;
  color: #9C3626;
  font-weight: 500;
}

/* Card đã ghép đôi */
.card.matched .card-front {
  border-color: #4CAF50;
  box-shadow: 0 4px 20px rgba(76, 175, 80, 0.3);
}

.card.matched .card-front .hanzi {
  color: #2e7d32;
}

/* ========================================
   WIN OVERLAY
   ======================================== */
.win-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.8);
  backdrop-filter: blur(8px);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}

.win-overlay.show {
  display: flex;
}

.win-content {
  background: linear-gradient(145deg, #2a2a4a, #1a1a3a);
  padding: 48px 64px;
  border-radius: 24px;
  text-align: center;
  border: 2px solid rgba(255,255,255,0.1);
  max-width: 500px;
  animation: popIn 0.5s ease;
}

@keyframes popIn {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.win-content .emoji {
  font-size: 4rem;
  margin-bottom: 12px;
}

.win-content h2 {
  font-size: 2rem;
  margin-bottom: 8px;
}

.win-content .stats {
  color: #aab;
  margin-bottom: 20px;
}

.win-content .stats span {
  color: white;
  font-weight: 600;
}

.win-content button {
  background: #9C3626;
  border: none;
  color: white;
  padding: 12px 32px;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.win-content button:hover {
  background: #b3402e;
  transform: scale(1.05);
}

/* ========================================
   RESPONSIVE
   ======================================== */
@media (max-width: 768px) {
  .game-header h1 {
    font-size: 1.6rem;
  }
  
  .game-board {
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 8px;
    padding: 6px;
  }
  
  .card-front .hanzi {
    font-size: 1.2rem;
  }
  
  .card-front .pinyin,
  .card-front .meaning {
    font-size: 0.6rem;
  }
  
  .controls {
    flex-direction: column;
    align-items: stretch;
  }
  
  .controls .stats {
    margin-left: 0;
    justify-content: center;
  }
  
  .win-content {
    padding: 32px 24px;
    margin: 20px;
  }
}

@media (max-width: 480px) {
  .game-board {
    grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
    gap: 6px;
  }
  
  .card-front .hanzi {
    font-size: 1rem;
  }
  
  .card-front .pinyin,
  .card-front .meaning {
    display: none;
  }
}
