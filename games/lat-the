/* ============================================================
   LOGIC TRÒ CHƠI
   ============================================================ */
let currentCards = [];
let flippedCards = [];
let matchedPairs = 0;
let totalPairs = 0;
let flipCount = 0;
let isLocked = false;
let timer = null;

const board = document.getElementById('gameBoard');
const levelSelect = document.getElementById('levelSelect');
const pairCountSelect = document.getElementById('pairCount');
const matchCountEl = document.getElementById('matchCount');
const totalPairsEl = document.getElementById('totalPairs');
const flipCountEl = document.getElementById('flipCount');
const winOverlay = document.getElementById('winOverlay');
const finalFlipsEl = document.getElementById('finalFlips');

// Hàm xáo trộn mảng (Fisher-Yates)
function shuffle(array) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

// Hàm lấy từ vựng theo cấp độ và số lượng
function getVocabulary(level, count) {
  const vocab = VOCABULARY[level] || VOCABULARY.hsk1;
  const shuffled = shuffle([...vocab]);
  return shuffled.slice(0, count);
}

// Hàm tạo bộ thẻ
function createCardDeck(words) {
  const deck = [];
  words.forEach((word, index) => {
    // Mỗi từ tạo 2 thẻ (cặp đôi)
    deck.push({ id: index, word, matched: false });
    deck.push({ id: index, word, matched: false });
  });
  return shuffle(deck);
}

// Hàm bắt đầu trò chơi
function startGame() {
  // Reset state
  winOverlay.classList.remove('show');
  flippedCards = [];
  matchedPairs = 0;
  flipCount = 0;
  isLocked = false;
  
  const level = levelSelect.value;
  const pairCount = parseInt(pairCountSelect.value);
  
  // Lấy từ vựng
  const words = getVocabulary(level, pairCount);
  totalPairs = words.length;
  
  // Tạo bộ thẻ
  currentCards = createCardDeck(words);
  
  // Cập nhật thông tin
  matchCountEl.textContent = '0';
  totalPairsEl.textContent = totalPairs;
  flipCountEl.textContent = '0';
  
  // Render board
  renderBoard();
}

// Hàm render board
function renderBoard() {
  board.innerHTML = currentCards.map((card, index) => `
    <div class="card" data-index="${index}" onclick="flipCard(${index})">
      <div class="card-inner">
        <div class="card-front">
          <span class="hanzi">${card.word.hanzi}</span>
          <span class="pinyin">${card.word.pinyin}</span>
          <span class="meaning">${card.word.meaning}</span>
        </div>
        <div class="card-back"></div>
      </div>
    </div>
  `).join('');
}

// Hàm lật thẻ
function flipCard(index) {
  // Kiểm tra điều kiện
  if (isLocked) return;
  
  const cardElement = document.querySelector(`.card[data-index="${index}"]`);
  const card = currentCards[index];
  
  // Không lật thẻ đã matched hoặc đã lật
  if (card.matched) return;
  if (flippedCards.includes(index)) return;
  if (flippedCards.length >= 2) return;
  
  // Lật thẻ
  cardElement.classList.add('flipped');
  flippedCards.push(index);
  
  // Nếu lật được 2 thẻ
  if (flippedCards.length === 2) {
    flipCount++;
    flipCountEl.textContent = flipCount;
    checkMatch();
  }
}

// Hàm kiểm tra cặp thẻ
function checkMatch() {
  isLocked = true;
  
  const [idx1, idx2] = flippedCards;
  const card1 = currentCards[idx1];
  const card2 = currentCards[idx2];
  
  // So sánh id (cùng từ vựng)
  if (card1.id === card2.id && idx1 !== idx2) {
    // Ghép đôi thành công
    setTimeout(() => {
      card1.matched = true;
      card2.matched = true;
      
      const el1 = document.querySelector(`.card[data-index="${idx1}"]`);
      const el2 = document.querySelector(`.card[data-index="${idx2}"]`);
      el1.classList.add('matched');
      el2.classList.add('matched');
      
      matchedPairs++;
      matchCountEl.textContent = matchedPairs;
      
      flippedCards = [];
      isLocked = false;
      
      // Kiểm tra chiến thắng
      if (matchedPairs === totalPairs) {
        setTimeout(() => {
          finalFlipsEl.textContent = flipCount;
          winOverlay.classList.add('show');
        }, 500);
      }
    }, 500);
  } else {
    // Không khớp, úp lại
    setTimeout(() => {
      const el1 = document.querySelector(`.card[data-index="${idx1}"]`);
      const el2 = document.querySelector(`.card[data-index="${idx2}"]`);
      el1.classList.remove('flipped');
      el2.classList.remove('flipped');
      
      flippedCards = [];
      isLocked = false;
    }, 1000);
  }
}

// Hàm reset game (chơi lại với cùng cài đặt)
function resetGame() {
  startGame();
}

